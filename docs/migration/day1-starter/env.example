# ===== liverico 環境変数テンプレート（Day1〜）=====
# 値は入れず、本物は Railway Variables / ローカル .env にだけ置く。秘密はコミットしない。

# --- DB（TiDB保持・引き継ぎ）---
DATABASE_URL=            # 本番TiDB接続文字列（mysql://...?ssl=...）
DATABASE_URL_DEV=        # 開発用の別DB/別接続（本番に触れない）

# --- 認証（引き継ぎ必須）---
JWT_SECRET=              # ★変更厳禁（変えると全セッション無効化）。現行と同じ値を移す
GOOGLE_CLIENT_ID=        # 現行のクライアントID再利用可
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=     # 移行先ドメインのコールバックに更新（例 https://liverico.app/api/oauth/google/callback）

# --- LLM（Forge→Anthropicへ差し替え：OpenAI互換窓口）---
LLM_API_URL=             # AnthropicのOpenAI互換エンドポイント
LLM_API_KEY=
LLM_MODEL_CLASSIFY=      # 例 claude-haiku-4-5（安い分類用）
LLM_MODEL_EXTRACT=       # 例 claude-sonnet-4-6（抽出用）

# --- 画像（Forge→Cloudflare R2）---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=      # 公開配信のベースURL（CDN）

# --- Cron（Heartbeat差し替え）---
CRON_SECRET=             # Railway Cron→/api/scheduled/* のBearer検証用

# --- 観測性 ---
SENTRY_DSN=

# --- 外部API（引き継ぎ・直接呼び）---
TAVILY_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=       # .p8の中身。秘密。Railway Variablesのみ
RESEND_API_KEY=
SETLIST_FM_API_KEY=

# --- 開発のみ ---
DEV_AUTH_BYPASS=         # 開発環境のみ
DEV_USER_EMAIL=

# --- 移行後に不要（削除予定）---
# BUILT_IN_FORGE_API_URL / BUILT_IN_FORGE_API_KEY / OAUTH_SERVER_URL /
# VITE_OAUTH_PORTAL_URL / VITE_APP_ID / VITE_FRONTEND_FORGE_API_KEY / VITE_FRONTEND_FORGE_API_URL
